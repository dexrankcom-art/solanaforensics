</BaseLayout>

<script>
  // --- Terminal typewriter animation (complete overhaul) ---
  interface TermLine {
    type: 'command' | 'output' | 'success' | 'alert' | 'detail' | 'blank';
    text: string;
    delay: number;
  }

  const LINES: TermLine[] = [
    { type: 'command', text: '$ trace --wallet HdHZ...kQ3s',         delay: 300 },
    { type: 'output',  text: 'Initializing trace engine...',          delay: 400 },
    { type: 'success', text: '✓ Connected to Helius RPC',            delay: 150 },
    { type: 'success', text: '✓ Loaded 1,247 transactions',          delay: 150 },
    { type: 'success', text: '✓ Cross-referencing Arkham clusters',  delay: 1000 },
    { type: 'blank',   text: '',                                      delay: 0 },
    { type: 'alert',   text: '⚠ HIGH RISK wallet detected',          delay: 300 },
    { type: 'detail',  text: '— Linked to 3 flagged entities',       delay: 100 },
    { type: 'detail',  text: '— $842,000 extracted (6 hops)',        delay: 100 },
    { type: 'detail',  text: '— Last active: 2h ago',                delay: 100 },
    { type: 'blank',   text: '',                                      delay: 600 },
    { type: 'command', text: '$ export --format law_enforcement_pdf', delay: 400 },
    { type: 'success', text: '✓ Report generated → report_001.pdf',  delay: 0 },
  ];

  let hasPlayed = false;
  const successLineEls: HTMLElement[] = [];

  const wait = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  function buildLine(line: TermLine): HTMLElement {
    const p = document.createElement('p');
    p.className = 'term-line';

    if (line.type === 'blank') {
      p.innerHTML = '&nbsp;';
      return p;
    }
    if (line.type === 'command') {
      const dollar = document.createElement('span');
      dollar.className = 't-prompt';
      dollar.textContent = '$';
      const rest = document.createElement('span');
      rest.className = 't-cmd';
      rest.textContent = line.text.slice(1);
      p.appendChild(dollar);
      p.appendChild(rest);
      return p;
    }
    if (line.type === 'success') {
      const check = document.createElement('span');
      check.className = 't-ok-char';
      check.textContent = '✓';
      const rest = document.createElement('span');
      rest.textContent = line.text.slice(1);
      if (line.text.includes('report_001.pdf')) {
        const parts = line.text.slice(1).split('report_001.pdf');
        rest.textContent = parts[0];
        const fileRef = document.createElement('span');
        fileRef.className = 't-file-ref';
        fileRef.textContent = 'report_001.pdf';
        p.appendChild(check);
        p.appendChild(rest);
        p.appendChild(fileRef);
        return p;
      }
      p.appendChild(check);
      p.appendChild(rest);
      return p;
    }
    if (line.type === 'alert') {
      const warn = document.createElement('span');
      warn.className = 't-warn-icon';
      warn.textContent = '⚠';
      const space = document.createTextNode(' ');
      const hr = document.createElement('span');
      hr.className = 't-danger';
      hr.textContent = 'HIGH RISK';
      const rest = document.createTextNode(' wallet detected');
      p.appendChild(warn);
      p.appendChild(space);
      p.appendChild(hr);
      p.appendChild(rest);
      return p;
    }
    if (line.type === 'detail') {
      const span = document.createElement('span');
      span.className = 't-dim';
      if (line.text.includes('$842,000')) {
        const parts = line.text.split('$842,000');
        span.textContent = parts[0];
        const money = document.createElement('span');
        money.className = 't-danger';
        money.textContent = '$842,000';
        const rest = document.createTextNode(parts[1]);
        p.appendChild(span);
        p.appendChild(money);
        p.appendChild(rest);
        return p;
      }
      span.textContent = line.text;
      p.appendChild(span);
      return p;
    }
    // output
    const span = document.createElement('span');
    span.className = 't-muted';
    span.textContent = line.text;
    p.appendChild(span);
    return p;
  }

  function typeChars(p: HTMLElement, speed: number): Promise<void> {
    return new Promise(resolve => {
      const nodes = Array.from(p.childNodes);
      const segments: { node: Text; full: string }[] = [];
      nodes.forEach(n => {
        if (n.nodeType === Node.TEXT_NODE) {
          segments.push({ node: n as Text, full: (n as Text).textContent || '' });
          (n as Text).textContent = '';
        } else if (n.nodeType === Node.ELEMENT_NODE) {
          const el = n as HTMLElement;
          el.querySelectorAll('*').forEach(c => {
            const walk = document.createTreeWalker(c, NodeFilter.SHOW_TEXT);
            let tn: Text | null;
            while ((tn = walk.nextNode() as Text | null)) {
              segments.push({ node: tn, full: tn.textContent || '' });
              tn.textContent = '';
            }
          });
          const walk = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, {
            acceptNode: (node) => node.parentNode === el ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_SKIP
          });
          let tn: Text | null;
          while ((tn = walk.nextNode() as Text | null)) {
            segments.push({ node: tn, full: tn.textContent || '' });
            tn.textContent = '';
          }
        }
      });

      // Flatten to char queue
      const chars: { seg: number; char: string }[] = [];
      segments.forEach((s, si) => {
        for (const ch of s.full) chars.push({ seg: si, char: ch });
      });

      // Add cursor at end of p
      const cursor = document.createElement('span');
      cursor.className = 'typing-cursor';
      cursor.textContent = '█';
      p.appendChild(cursor);

      let ci = 0;
      const tick = () => {
        if (ci < chars.length) {
          const c = chars[ci];
          segments[c.seg].node.textContent += c.char;
          ci++;
          setTimeout(tick, speed);
        } else {
          cursor.remove();
          resolve();
        }
      };
      tick();
    });
  }

  function flashSuccess(p: HTMLElement) {
    const check = p.querySelector('.t-ok-char');
    if (check) {
      (check as HTMLElement).classList.add('flash-green');
      setTimeout(() => (check as HTMLElement).classList.remove('flash-green'), 400);
    }
  }

  function updateProgress(progress: number) {
    const bar = document.getElementById('term-progress');
    if (bar) bar.style.width = progress + '%';
  }

  async function runAnimation() {
    if (hasPlayed) return;
    hasPlayed = true;

    const output = document.getElementById('terminal-output');
    const termEl = document.getElementById('hero-terminal');
    if (!output || !termEl) return;
    output.innerHTML = '';
    successLineEls.length = 0;

    // Phase 1: initial blinking cursor
    const initCursor = document.createElement('p');
    initCursor.className = 'term-line';
    const ic = document.createElement('span');
    ic.className = 'typing-cursor';
    ic.textContent = '█';
    initCursor.appendChild(ic);
    output.appendChild(initCursor);
    await wait(500);
    initCursor.remove();

    const totalLines = LINES.length;

    for (let li = 0; li < totalLines; li++) {
      const line = LINES[li];
      const p = buildLine(line);
      output.appendChild(p);
      p.classList.add('term-active');

      updateProgress(((li + 0.5) / totalLines) * 100);

      if (line.type === 'blank') {
        // Just show empty line
      } else if (line.type === 'command') {
        await typeChars(p, 35);
        // Brief cursor blink pause after command
        const blinkCursor = document.createElement('span');
        blinkCursor.className = 'typing-cursor';
        blinkCursor.textContent = '█';
        p.appendChild(blinkCursor);
        await wait(300);
        blinkCursor.remove();
      } else if (line.type === 'output') {
        await typeChars(p, 20);
      } else if (line.type === 'success') {
        // Appears instantly
        flashSuccess(p);
        successLineEls.push(p);
      } else if (line.type === 'alert') {
        // Types character by character
        await typeChars(p, 25);
        // Red glow pulse on the line
        p.classList.add('alert-flash');
        // Terminal border + shadow flash
        termEl.classList.add('term-alert');
        // Screen shake
        termEl.classList.add('term-shake');
        setTimeout(() => termEl.classList.remove('term-shake'), 200);
        setTimeout(() => {
          termEl.classList.remove('term-alert');
          p.classList.remove('alert-flash');
        }, 500);
      } else if (line.type === 'detail') {
        // Appears instantly (already built)
      }

      p.classList.remove('term-active');
      p.classList.add('typed');
      output.scrollTop = output.scrollHeight;

      updateProgress(((li + 1) / totalLines) * 100);

      if (line.delay > 0) await wait(line.delay);
    }

    // File ref brief underline
    const fileRef = output.querySelector('.t-file-ref') as HTMLElement;
    if (fileRef) {
      fileRef.classList.add('file-flash');
      setTimeout(() => fileRef.classList.remove('file-flash'), 800);
    }

    // Final blinking cursor
    const finalCursor = document.createElement('p');
    finalCursor.className = 'term-line';
    const fc = document.createElement('span');
    fc.className = 'cursor mono';
    fc.textContent = '█';
    finalCursor.appendChild(fc);
    output.appendChild(finalCursor);

    // Fade out progress bar
    const bar = document.getElementById('term-progress');
    if (bar) bar.classList.add('term-progress-done');

    // Enter idle state
    termEl.classList.add('term-idle');

    // Phase 3: idle health-check flashes
    setInterval(() => {
      if (successLineEls.length === 0) return;
      const idx = Math.floor(Math.random() * successLineEls.length);
      const el = successLineEls[idx];
      const check = el.querySelector('.t-ok-char') as HTMLElement;
      if (check) {
        check.classList.add('flash-green');
        setTimeout(() => check.classList.remove('flash-green'), 400);
      }
    }, 8000 + Math.random() * 2000);
  }

  function showAllImmediate() {
    const output = document.getElementById('terminal-output');
    if (!output || hasPlayed) return;
    hasPlayed = true;
    output.innerHTML = '';
    for (const line of LINES) {
      const p = buildLine(line);
      p.classList.add('typed');
      output.appendChild(p);
      if (line.type === 'success') successLineEls.push(p);
    }
    const finalCursor = document.createElement('p');
    finalCursor.className = 'term-line';
    const fc = document.createElement('span');
    fc.className = 'cursor mono';
    fc.textContent = '█';
    finalCursor.appendChild(fc);
    output.appendChild(finalCursor);
    const bar = document.getElementById('term-progress');
    if (bar) bar.style.display = 'none';
  }

  const terminal = document.getElementById('hero-terminal');
  if (terminal) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const termObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          prefersReduced ? showAllImmediate() : runAnimation();
          termObserver.disconnect();
        }
      });
    }, { threshold: 0.5 });
    termObserver.observe(terminal);
  }

  // --- Scroll-triggered reveal animations ---
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // --- Hero grid-bg ambient spotlight ---
    const hero = document.querySelector('.hero.grid-bg') as HTMLElement;
    if (hero) {
      hero.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        hero.style.setProperty('--mouse-x', x + '%');
        hero.style.setProperty('--mouse-y', y + '%');
      });
    }

    // --- Feature card hover glow ---
    document.querySelectorAll('.feature-card').forEach(card => {
      card.addEventListener('mousemove', (e: Event) => {
        const me = e as MouseEvent;
        const el = card as HTMLElement;
        const rect = el.getBoundingClientRect();
        el.style.setProperty('--card-mouse-x', (me.clientX - rect.left) + 'px');
        el.style.setProperty('--card-mouse-y', (me.clientY - rect.top) + 'px');
      });
    });

    // --- Stat count-up animation ---
    const countEl = document.querySelector('[data-count-to]') as HTMLElement;
    if (countEl) {
      const target = parseInt(countEl.dataset.countTo || '0', 10);
      const suffix = countEl.dataset.countSuffix || '';
      let counted = false;
      const countObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !counted) {
            counted = true;
            countObserver.disconnect();
            const duration = 1500;
            const start = performance.now();
            const step = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              countEl.textContent = Math.floor(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          }
        });
      }, { threshold: 0.5 });
      countObserver.observe(countEl);
    }
  } else {
    document.querySelectorAll('.reveal').forEach(el => el.classList.add('revealed'));
    const countEl = document.querySelector('[data-count-to]') as HTMLElement;
    if (countEl) {
      countEl.textContent = (countEl.dataset.countTo || '0') + (countEl.dataset.countSuffix || '');
    }
  }

  // --- Particle network canvas ---
  (function() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth < 768) return;

    const canvas = document.getElementById('particle-network') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width: number, height: number;
    let mouseX = -1000, mouseY = -1000;
    const PARTICLE_COUNT = 55;
    const HUB_COUNT = 5;
    const CONNECTION_DIST = 150;
    const MOUSE_RADIUS = 200;

    interface Particle {
      x: number; y: number;
      vx: number; vy: number;
      size: number; opacity: number;
    }

    const particles: Particle[] = [];

    function resize() {
      const hero = canvas.parentElement;
      if (!hero) return;
      const rect = hero.getBoundingClientRect();
      width = canvas.width = rect.width;
      height = canvas.height = rect.height;
    }

    function createParticles() {
      particles.length = 0;
      for (let i = 0; i < PARTICLE_COUNT + HUB_COUNT; i++) {
        const isHub = i >= PARTICLE_COUNT;
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          size: isHub ? Math.random() * 1.5 + 2.5 : Math.random() * 2 + 1,
          opacity: isHub ? Math.random() * 0.25 + 0.45 : Math.random() * 0.5 + 0.2,
        });
      }
    }

    function animate() {
      ctx!.clearRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];

        const dx = mouseX - p.x;
        const dy = mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MOUSE_RADIUS && dist > 0) {
          const force = (MOUSE_RADIUS - dist) / MOUSE_RADIUS * 0.02;
          p.vx += dx / dist * force;
          p.vy += dy / dist * force;
        }

        p.vx *= 0.99;
        p.vy *= 0.99;
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < 0 || p.x > width) p.vx *= -1;
        if (p.y < 0 || p.y > height) p.vy *= -1;
        p.x = Math.max(0, Math.min(width, p.x));
        p.y = Math.max(0, Math.min(height, p.y));

        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(0, 212, 255, ${p.opacity})`;
        ctx!.fill();
      }

      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < CONNECTION_DIST) {
            const opacity = (1 - dist / CONNECTION_DIST) * 0.15;
            ctx!.beginPath();
            ctx!.moveTo(particles[i].x, particles[i].y);
            ctx!.lineTo(particles[j].x, particles[j].y);
            ctx!.strokeStyle = `rgba(0, 212, 255, ${opacity})`;
            ctx!.lineWidth = 0.5;
            ctx!.stroke();
          }
        }
      }

      requestAnimationFrame(animate);
    }

    const hero = canvas.parentElement;
    if (hero) {
      hero.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
      });
      hero.addEventListener('mouseleave', () => {
        mouseX = -1000;
        mouseY = -1000;
      });
    }

    window.addEventListener('resize', resize);
    resize();
    createParticles();
    animate();
  })();
</script>

