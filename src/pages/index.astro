          <span>Track. Trace.<br/><span class="accent glow-text">Expose.</span></span>
          <span class="sr-only">Solana Blockchain Forensic Investigation Agent</span>
        </h1>
        <p class="hero-sub">
          A forensic intelligence agent for Solana investigations. Trace wallets, map CEX cashouts, and generate law-enforcement-ready reports — powered by Clavestra Intel.
        </p>
        <div class="hero-actions">
          <a href="https://t.me/solanaforensics_bot" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Start on Telegram →</a>
          <a href="/features" class="btn btn-outline">See Features</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-val mono" data-count-to="500" data-count-suffix="M+">0</span>
            <span class="stat-label">Transactions Indexed</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-val mono">Real-time</span>
            <span class="stat-label">Wallet Monitoring</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-val mono">LE-Ready</span>
            <span class="stat-label">Report Formats</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="terminal" id="hero-terminal">
          <div class="terminal-bar">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="terminal-title mono">solana_forensics — wallet_trace</span>
          </div>
          <div class="term-progress" id="term-progress"></div>
          <div class="terminal-body mono" id="terminal-output"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how-it-works">
    <div class="container">
      <div class="section-header">
        <div class="tag reveal">// How It Works</div>
        <h2 class="reveal section-h2">Forensic intelligence via <span class="accent">Telegram.</span></h2>
        <p class="section-sub reveal">No dashboards. No logins. Just open Telegram and start investigating.</p>
      </div>

      <div class="hiw-steps reveal-stagger">
