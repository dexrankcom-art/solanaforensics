---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="SolanaForensics — Solana Blockchain Forensic Intelligence Agent">

  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "SolanaForensics",
    "url": "https://solanaforensics.com"
  })} />

  <!-- HERO -->
