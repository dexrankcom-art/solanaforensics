    <div class="container">
      <p class="context-label mono reveal">// Built for investigation professionals</p>
      <div class="context-items reveal">
        <span>Law Enforcement</span>
        <span class="sep">—</span>
        <span>Financial Intelligence Units</span>
        <span class="sep">—</span>
        <span>Compliance Teams</span>
        <span class="sep">—</span>
        <span>Forensic Investigators</span>
