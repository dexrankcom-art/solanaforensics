---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true">
            <polygon points="14,2 26,8 26,20 14,26 2,20 2,8" stroke="#00d4ff" stroke-width="1.5" fill="none"/>
            <circle cx="14" cy="14" r="3" fill="#00d4ff"/>
          </svg>
          <span>Solana<span style="color:var(--accent)">Forensics</span></span>
        </a>
        <p class="footer-tagline">Forensic-grade on-chain intelligence for the Solana blockchain.</p>
        <p class="footer-powered">Powered by <span class="accent">Clavestra Intel</span></p>
        <div class="footer-socials">
          <a href="https://x.com/solanaforensics" target="_blank" rel="noopener noreferrer" aria-label="Follow SolanaForensics on X" class="footer-social">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://t.me/solanaforensics_bot" target="_blank" rel="noopener noreferrer" aria-label="SolanaForensics on Telegram" class="footer-social">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Platform</h4>
        <a href="/features">Features</a>
        <a href="/use-cases">Use Cases</a>
        <a href="/blog">Reports</a>
        <a href="/contact">Request Access</a>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <a href="https://x.com/solanaforensics" target="_blank" rel="noopener noreferrer">X / Twitter</a>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="/disclaimer">Disclaimer</a>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="mono" style="color: var(--text-dim); font-size: 0.75rem;">
        © {year} SolanaForensics. All rights reserved.
      </span>
      <span class="mono" style="color: var(--text-dim); font-size: 0.75rem;">
        A <span style="color: var(--accent)">Clavestra Intel</span> product.
      </span>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--border);
  padding: 5rem 0 2rem;
  margin-top: 4rem;
  background: var(--bg-2);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 4rem;
}

.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  font-family: var(--sans);
  font-weight: 800;
  font-size: 1.1rem;
  color: var(--text);
  margin-bottom: 1rem;
}

.footer-tagline {
  color: var(--text-muted);
  font-size: 0.9rem;
  line-height: 1.6;
  margin-bottom: 1rem;
  max-width: 280px;
}

.footer-powered {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--text-dim);
  letter-spacing: 0.05em;
}
.footer-powered .accent { color: var(--accent); }

.footer-socials {
  display: flex;
  gap: 0.75rem;
  margin-top: 1.25rem;
}

.footer-social {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid var(--border);
  color: var(--text-muted);
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}

.footer-social:hover {
  color: var(--accent);
  border-color: var(--accent);
  background: var(--accent-dim2);
}

.footer-col h4 {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 1.25rem;
  font-weight: 400;
}

.footer-col a {
  display: block;
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 0.65rem;
  text-decoration: none;
  transition: color 0.2s;
}
.footer-col a:hover { color: var(--accent); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}

@media (max-width: 768px) {
  .footer { padding: 3.5rem 0 1.5rem; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2.5rem; }
  .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  .footer-col a {
    padding: 0.5rem 0;
    font-size: 0.88rem;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .footer-tagline { font-size: 0.85rem; }
}

@media (max-width: 480px) {
  .footer { padding: 2.5rem 0 1.25rem; margin-top: 2rem; }
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; margin-bottom: 2rem; }
  .footer-col a { font-size: 0.85rem; min-height: 44px; }
  .footer-col h4 { margin-bottom: 0.75rem; }
  .footer-bottom span {
    font-size: 0.72rem !important;
  }
}

@media (max-width: 320px) {
  .footer-logo { font-size: 1rem; }
}
</style>
